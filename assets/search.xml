<?xml version="1.0" encoding="UTF-8"?>
<OpenSearchDescription xmlns="http://a9.com/-/spec/opensearch/1.1/">
<ShortName>Twint Search</ShortName>
<Description>An add-on for any search engine that adds Kagi's bang system.</Description>
<InputEncoding>UTF-8</InputEncoding>
<Image height="32" width="32" type="image/png">https://search.{domain}/favicon.png</Image>
<Url type="text/html" method="GET" template="https://search.{domain}/s?q={searchTerms}"/>
<Url type="application/x-suggestions+json" method="GET" template="https://search.{domain}/c?q={searchTerms}"/>
</OpenSearchDescription>